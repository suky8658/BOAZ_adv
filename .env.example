# Source database
SOURCE_DB_USER=your_source_user
SOURCE_DB_PASSWORD=your_source_password
SOURCE_DB_HOST=127.0.0.1
SOURCE_DB_PORT=3306
SOURCE_DB_NAME=olist

# Datamart database
DATAMART_DB_USER=your_datamart_user
DATAMART_DB_PASSWORD=your_datamart_password
DATAMART_DB_HOST=127.0.0.1
DATAMART_DB_PORT=3306
DATAMART_DB_NAME=analytics

# Agent runtime
GOOGLE_API_KEY=your_google_api_key
AGENT_MODEL=google_genai:gemini-2.5-flash
ALLOW_MART_WRITE=true

# Optional tuning
MAX_RESULT_ROWS=200
MAX_RESULT_PREVIEW_ROWS=20
